# AWS SNS Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# Business phone number (must be verified in SNS Sandbox)
# Format: +1XXXXXXXXXX for US numbers
BUSINESS_PHONE_NUMBER=+17202557466

# Toll-Free number (uncomment when you have it)
# TOLL_FREE_NUMBER=+18001234567

# CORS Configuration
# Development: http://localhost:5173 or http://localhost:3000
# Production: https://yourdomain.com
ALLOWED_ORIGIN=http://localhost:5173

UPSTASH_REDIS_REST_URL=url-here
UPSTASH_REDIS_REST_TOKEN=token-here

# Rate limiting
RATE_LIMIT_STORE=memory
RATE_LIMIT_IP_POINTS=3
RATE_LIMIT_IP_DURATION_SECONDS=3600
RATE_LIMIT_IP_BLOCK_SECONDS=3600
RATE_LIMIT_GLOBAL_POINTS=50
RATE_LIMIT_GLOBAL_DURATION_SECONDS=3600

# Development-only SMS logging mode
SMS_DEV_LOG_ONLY=false
SMS_DEV_LOG_PATH=logs/contact-messages.log

# Cloudflare Turnstile
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Local testing mode for Turnstile
# Set both flags to true to force Cloudflare's official test keys.
VITE_TURNSTILE_USE_TEST_KEYS=false
TURNSTILE_USE_TEST_KEYS=false

# Optional test behavior: pass, fail, interactive
VITE_TURNSTILE_TEST_BEHAVIOR=pass

# Optional server-side test behavior: pass or fail
TURNSTILE_TEST_BEHAVIOR=pass
