# AWS SNS Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# Business phone number (must be verified in SNS Sandbox)
# Format: +1XXXXXXXXXX for US numbers
BUSINESS_PHONE_NUMBER=+17202557466

# Toll-Free number (uncomment when you have it)
# TOLL_FREE_NUMBER=+18001234567

# CORS Configuration
# Development: http://localhost:5173 or http://localhost:3000
# Production: https://yourdomain.com
ALLOWED_ORIGIN=http://localhost:5173